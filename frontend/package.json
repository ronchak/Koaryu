{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "analyze": "next build --experimental-analyze",
    "start": "next start",
    "lint": "eslint",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "test:e2e": "playwright test e2e",
    "test:e2e:preview-smoke": "KOARYU_PREVIEW_SMOKE_E2E=true playwright test e2e/preview-smoke.spec.ts",
    "test:e2e:preview-import": "KOARYU_PREVIEW_E2E=true playwright test e2e/student-import-idempotency-key.spec.ts",
    "test:e2e:live-belt": "KOARYU_LIVE_STATEFUL_E2E=true playwright test e2e/atomic-belt-ladder.spec.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "lucide-react": "^1.8.0",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
