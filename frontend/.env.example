# Koaryu Frontend Environment Variables
# Copy this to .env.local and fill in your values

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# Server-only: preferred backend API base for Next.js API proxy and cron routes.
BACKEND_API_URL=http://127.0.0.1:8001/api/v1
# Server-only: Vercel uses this to authenticate scheduled cron requests.
CRON_SECRET=long-random-secret-for-vercel-cron
# Server-only: must match the backend ACCOUNT_DELETION_WORKER_SECRET.
ACCOUNT_DELETION_WORKER_SECRET=long-random-secret-for-the-deletion-worker
# Optional: set true only if you need browser API calls to route through Next.
NEXT_PUBLIC_USE_API_PROXY=false
# Optional: set true only for static preview/demo data instead of live auth/API.
NEXT_PUBLIC_PREVIEW_MODE=false
# Optional rollout switch: set false to use the legacy full-roster Students page.
NEXT_PUBLIC_STUDENTS_PAGED_ROSTER=true
# Optional diagnostics: set true temporarily to log Koaryu performance marks and web vitals in production.
NEXT_PUBLIC_KOARYU_PERFORMANCE_DEBUG=false

# Vercel supplies VERCEL_GIT_COMMIT_SHA, VERCEL_ENV, and VERCEL_TARGET_ENV.
# /api/version validates those system values before returning public metadata;
# do not duplicate them here or store secrets in them.
