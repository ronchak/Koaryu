{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koaryu.local/schemas/recovery/backup-set-manifest-v1.json",
  "title": "Koaryu canonical encrypted backup-set manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "backup_set_id",
    "created_at",
    "source",
    "tools",
    "encryption",
    "retention_class",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "backup_set_id": { "$ref": "#/$defs/backupSetId" },
    "created_at": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/source" },
    "tools": { "$ref": "#/$defs/tools" },
    "encryption": { "$ref": "#/$defs/encryption" },
    "retention_class": { "$ref": "#/$defs/safeId" },
    "artifacts": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/artifact" },
      "allOf": [
        { "contains": { "properties": { "name": { "const": "roles.sql.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "schema.sql.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "data.sql.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "migration-history-schema.sql.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "migration-history-data.sql.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "project-config-manifest.json.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "restore-integrity-manifest.json.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "classification-source.json.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "record-classification-manifest.json.gpg" } }, "required": ["name"] } },
        { "contains": { "properties": { "name": { "const": "storage-objects.tar.gpg" } }, "required": ["name"] } }
      ]
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "safeId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "keyId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$" },
    "backupSetId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_ref",
        "captured_at",
        "database_snapshot_digest",
        "application_sha",
        "repository_migration_head",
        "remote_migration_history_digest"
      ],
      "properties": {
        "project_ref": { "type": "string", "pattern": "^[a-z]{20}$" },
        "captured_at": { "type": "string", "format": "date-time" },
        "database_snapshot_digest": { "$ref": "#/$defs/sha256" },
        "application_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "repository_migration_head": { "type": "string", "pattern": "^[0-9]{14}_[a-z0-9_]+\\.sql$" },
        "remote_migration_history_digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["postgres", "supabase_cli", "gpg"],
      "properties": {
        "postgres": { "type": "string", "minLength": 1, "maxLength": 80 },
        "supabase_cli": { "type": "string", "minLength": 1, "maxLength": 80 },
        "gpg": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheme",
        "key_id",
        "s2k_mode",
        "s2k_digest",
        "s2k_count",
        "aead_chunk_size"
      ],
      "properties": {
        "scheme": { "const": "gpg-aes256-ocb" },
        "key_id": { "$ref": "#/$defs/keyId" },
        "s2k_mode": { "const": 3 },
        "s2k_digest": { "const": "SHA512" },
        "s2k_count": { "const": 65011712 },
        "aead_chunk_size": { "const": 22 }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "size_bytes",
        "sha256",
        "plaintext_size_bytes",
        "plaintext_sha256"
      ],
      "properties": {
        "name": {
          "enum": [
            "roles.sql.gpg",
            "schema.sql.gpg",
            "data.sql.gpg",
            "migration-history-schema.sql.gpg",
            "migration-history-data.sql.gpg",
            "project-config-manifest.json.gpg",
            "restore-integrity-manifest.json.gpg",
            "classification-source.json.gpg",
            "record-classification-manifest.json.gpg",
            "storage-objects.tar.gpg"
          ]
        },
        "role": {
          "enum": [
            "database_roles",
            "database_schema",
            "database_data",
            "migration_history_schema",
            "migration_history_data",
            "project_configuration",
            "restore_integrity",
            "classification_source",
            "record_classification",
            "storage_objects"
          ]
        },
        "size_bytes": { "type": "integer", "minimum": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "plaintext_size_bytes": { "type": "integer", "minimum": 1 },
        "plaintext_sha256": { "$ref": "#/$defs/sha256" },
        "plaintext_contract_sha256": { "$ref": "#/$defs/sha256" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "name": {
                "enum": [
                  "project-config-manifest.json.gpg",
                  "restore-integrity-manifest.json.gpg",
                  "classification-source.json.gpg",
                  "record-classification-manifest.json.gpg"
                ]
              }
            },
            "required": ["name"]
          },
          "then": { "required": ["plaintext_contract_sha256"] },
          "else": { "not": { "required": ["plaintext_contract_sha256"] } }
        },
        { "if": { "properties": { "name": { "const": "roles.sql.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "database_roles" } } } },
        { "if": { "properties": { "name": { "const": "schema.sql.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "database_schema" } } } },
        { "if": { "properties": { "name": { "const": "data.sql.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "database_data" } } } },
        { "if": { "properties": { "name": { "const": "migration-history-schema.sql.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "migration_history_schema" } } } },
        { "if": { "properties": { "name": { "const": "migration-history-data.sql.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "migration_history_data" } } } },
        { "if": { "properties": { "name": { "const": "project-config-manifest.json.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "project_configuration" } } } },
        { "if": { "properties": { "name": { "const": "restore-integrity-manifest.json.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "restore_integrity" } } } },
        { "if": { "properties": { "name": { "const": "classification-source.json.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "classification_source" } } } },
        { "if": { "properties": { "name": { "const": "record-classification-manifest.json.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "record_classification" } } } },
        { "if": { "properties": { "name": { "const": "storage-objects.tar.gpg" } }, "required": ["name"] }, "then": { "properties": { "role": { "const": "storage_objects" } } } }
      ]
    }
  }
}
