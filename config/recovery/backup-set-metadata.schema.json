{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koaryu.local/schemas/recovery/backup-set-metadata-v1.json",
  "title": "Koaryu backup-set metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "backup_set_id",
    "source",
    "tools",
    "encryption",
    "retention_class"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "backup_set_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_ref",
        "captured_at",
        "database_snapshot_digest",
        "application_sha",
        "repository_migration_head",
        "remote_migration_history_digest"
      ],
      "properties": {
        "project_ref": { "type": "string", "pattern": "^[a-z]{20}$" },
        "captured_at": { "type": "string", "format": "date-time" },
        "database_snapshot_digest": { "$ref": "#/$defs/sha256" },
        "application_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "repository_migration_head": { "type": "string", "pattern": "^[0-9]{14}_[a-z0-9_]+\\.sql$" },
        "remote_migration_history_digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["postgres", "supabase_cli", "gpg"],
      "properties": {
        "postgres": { "type": "string", "minLength": 1, "maxLength": 80 },
        "supabase_cli": { "type": "string", "minLength": 1, "maxLength": 80 },
        "gpg": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheme",
        "key_id",
        "s2k_mode",
        "s2k_digest",
        "s2k_count",
        "aead_chunk_size"
      ],
      "properties": {
        "scheme": { "const": "gpg-aes256-ocb" },
        "key_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$" },
        "s2k_mode": { "const": 3 },
        "s2k_digest": { "const": "SHA512" },
        "s2k_count": { "const": 65011712 },
        "aead_chunk_size": { "const": 22 }
      }
    },
    "retention_class": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
