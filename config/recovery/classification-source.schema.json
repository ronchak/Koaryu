{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koaryu.local/schemas/recovery/classification-source-v1.json",
  "title": "Koaryu privacy-safe production classification source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "backup_set_id",
    "source_snapshot_digest",
    "captured_at",
    "identifier_protection",
    "sources"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "backup_set_id": { "$ref": "#/$defs/backupSetId" },
    "source_snapshot_digest": { "$ref": "#/$defs/sha256" },
    "captured_at": { "type": "string", "format": "date-time" },
    "identifier_protection": { "$ref": "#/$defs/identifierProtection" },
    "sources": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/source" },
      "allOf": [
        { "contains": { "properties": { "source_type": { "const": "auth_user" } }, "required": ["source_type"] } },
        { "contains": { "properties": { "source_type": { "const": "studio" } }, "required": ["source_type"] } },
        { "contains": { "properties": { "source_type": { "const": "studio_subscription" } }, "required": ["source_type"] } },
        { "contains": { "properties": { "source_type": { "const": "studio_payment_account" } }, "required": ["source_type"] } },
        { "contains": { "properties": { "source_type": { "const": "stripe_event" } }, "required": ["source_type"] } }
      ]
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "safeId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "backupSetId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$" },
    "uuidRecordId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "stripeEventId": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9]{8,124}$"
    },
    "identifierProtection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email_strategy", "key_id"],
      "properties": {
        "email_strategy": { "const": "omitted" },
        "key_id": { "type": "null" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_count", "records"],
      "properties": {
        "source_type": {
          "enum": [
            "auth_user",
            "studio",
            "studio_subscription",
            "studio_payment_account",
            "stripe_event"
          ]
        },
        "source_count": { "type": "integer", "minimum": 0 },
        "records": { "type": "array" }
      },
      "allOf": [
        {
          "if": { "properties": { "source_type": { "const": "stripe_event" } }, "required": ["source_type"] },
          "then": { "properties": { "records": { "items": { "$ref": "#/$defs/stripeRecord" } } } },
          "else": { "properties": { "records": { "items": { "$ref": "#/$defs/uuidRecord" } } } }
        }
      ]
    },
    "uuidRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "evidence"],
      "properties": {
        "record_id": { "$ref": "#/$defs/uuidRecordId" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "stripeRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "evidence"],
      "properties": {
        "record_id": { "$ref": "#/$defs/stripeEventId" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "evidence": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "explicit_demo_metadata",
          "explicit_test_metadata",
          "provider_test_mode",
          "synthetic_fixture_identifier"
        ]
      }
    }
  }
}
