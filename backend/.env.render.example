# Koaryu API Render config vars
# Copy these names into Render. Do not commit real secret values.

FRONTEND_URL=https://koaryu.app
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
DEMO_RESET_ENABLED=false
DEMO_RESET_STUDIO_IDS=
BILLING_PLATFORM_FEE_BPS=50

SUPABASE_URL=https://mimguepumzsgmcaycdsh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_ALLOW_LEGACY_HS256=false

STRIPE_SECRET_KEY=sk_live_or_test_your_key
STRIPE_RESTRICTED_KEY=rk_live_or_test_your_key
STRIPE_PLATFORM_WEBHOOK_SECRET=whsec_your_platform_webhook_secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_platform_scope,whsec_your_connect_connected_scope
STRIPE_KOARYU_CORE_PRICE_ID=price_your_koaryu_core_subscription
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id

ACCOUNT_DELETION_WORKER_SECRET=long-random-secret-for-the-deletion-cron
SUPPORT_TRIAGE_SECRET=long-random-secret-for-support-ticket-triage

# Hosted startup validates these values before serving traffic. Render supplies
# RENDER_GIT_COMMIT automatically for the public health metadata; do not set it
# manually or copy a secret into it.
