# Koaryu Backend Environment Variables
# Copy this to .env and fill in your values

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_ALLOW_LEGACY_HS256=true
FRONTEND_URL=http://localhost:4000
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Set true only in controlled demo/staging contexts where demo reset should be callable.
DEMO_RESET_ENABLED=false
DEMO_RESET_STUDIO_IDS=

# Stripe test-mode billing
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_RESTRICTED_KEY=rk_test_your_restricted_key
STRIPE_PLATFORM_WEBHOOK_SECRET=whsec_your_platform_webhook_secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret
STRIPE_KOARYU_CORE_PRICE_ID=price_your_koaryu_core_subscription
BILLING_PLATFORM_FEE_BPS=50

# Internal worker/support shared secrets
ACCOUNT_DELETION_WORKER_SECRET=long-random-secret-for-the-deletion-worker
SUPPORT_TRIAGE_SECRET=long-random-secret-for-support-ticket-triage

# In ENVIRONMENT=staging or production, app startup fails if required Supabase,
# Stripe, internal-operation, or public frontend values are incomplete or unsafe.
# Staging additionally requires Koaryu's pinned staging origins and test Stripe keys.
# Render supplies RENDER_GIT_COMMIT automatically; do not set it from a secret.
